{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": "true",
  "enabledManagers": [
    "custom.regex"
  ],
  "labels": [
    "dependencies"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "charts/buildkit-service/Chart.yaml"
      ],
      "matchStrings": [
        "appVersion: (?<currentValue>.*?)\\n"
      ],
      "depNameTemplate": "moby/buildkit",
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchFileNames": [
        "charts/buildkit-service/Chart.yaml"
      ],
      "labels": [
        "dependencies",
        "buildkit-service"
      ]
    }
  ]
}
